<?xml version="1.0"?>
<launch>

  <include file="$(find-pkg-share rrm_sim)/launch/rrm_sim.launch.xml">
    <arg name="rviz2" value="false" />
  </include>

  <!-- 2. robot_state_publisher -->
	<node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher" output="screen">
		<param name="robot_description"	value="$(command 'cat $(find-pkg-share rrm_simple_robot_model)/urdf/arm.urdf')"/>
	</node>

  <!-- 3. joint_state GUI -->
  <!-- <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="joint_state_publisher_gui" output="screen"/> -->

  <!-- 4. rviz -->
  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(find-pkg-share cv6)/config/cv6.rviz"/>

  <!-- 5. logger node (проверь соответствие имени в CMakeLists.txt!) -->
  <node pkg="cv6" exec="logger_node" name="joint_logger" output="screen" />

  <!-- 6. IK solver and motion manager -->
  <node pkg="cv6" exec="ik_solver" name="ik_solver" output="screen" launch-prefix="xterm -e" />
  <node pkg="cv6" exec="motion_manager" name="motion_manager" output="screen" launch-prefix="xterm -e" />

</launch>